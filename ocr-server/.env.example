# Optional: use OpenAI Vision (gpt-4o) for receipt extraction. Often better for mixed language (e.g. English + Chinese) and messy layout. Costs per image.
# When set, the server uses AI first; if the request fails, it falls back to Tesseract OCR.
# OPENAI_API_KEY=sk-...

# Optional: use [receipt-ocr](https://github.com/bhimrazy/receipt-ocr) Tesseract service for OCR.
# When set, the server forwards images to this URL instead of using built-in tesseract.js.
# Run receipt-ocr first: see RECEIPT_OCR.md in the project root.
# RECEIPT_OCR_URL=http://localhost:8000

# Server port (default 3080)
# PORT=3080
