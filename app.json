{
  "expo": {
    "name": "EZSplit",
    "slug": "it-project",
    "version": "1.0.8",
    "orientation": "portrait",
    "scheme": "ezsplit",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "icon": "./assets/EZSplitLogo.png",
    "splash": {
      "image": "./assets/EZSplitSplash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0b100b"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.flairysm.ezsplit",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.flairysm.ezsplit",
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/EZSplitLogo.png",
        "backgroundColor": "#0b100b"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "EZSplit needs access to your photos to scan receipts.",
          "cameraPermission": "EZSplit needs camera access to take photos of receipts."
        }
      ],
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "67160189-2b72-43f6-9372-5d6f2528f6b1"
      },
      "router": {}
    },
    "owner": "flairysm"
  }
}
