# Optional: cloud OCR URL for production (no trailing slash).
# When set, the app uses this instead of the default local URL in app/config.ts.
# EXPO_PUBLIC_OCR_URL=https://ezsplit-ocr.onrender.com

# Optional: if your OCR server requires an API key, set the same value here.
# EXPO_PUBLIC_OCR_API_KEY=your-secret-key
